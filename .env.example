# Copy to .env.local for local dev. Optional at build time — the committed
# public/events.json snapshot is used when this is unset or the API returns nothing.
LUMA_API_KEY=your_luma_api_key_here

# For production live sync, set as a Worker secret (not a plain env var):
#   npx wrangler secret put LUMA_API_KEY
# If the secret is missing or invalid, the site falls back to public/events.json.
